# =============================================================================
# Flybase — machine/user-specific overrides.
#
# Copy to config/paths.local.sh (gitignored) and edit. Everything here wins
# over the defaults in config/paths.sh. You usually only need the conda block.
#
#   cp config/paths.local.sh.template config/paths.local.sh
#   $EDITOR config/paths.local.sh
# =============================================================================

# --- Conda (point at YOUR miniforge / env base) ------------------------------
# export CONDA_INIT_SCRIPT="/path/to/miniforge3/etc/profile.d/conda.sh"
