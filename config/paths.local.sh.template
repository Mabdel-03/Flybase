# FLY_CEL_REP_* target the Drosophila root, FLY_CEL_REP_INTERSPECIES_* the other.
# export FLY_CEL_REP_DATA="${REPO_ROOT}/2 - Cel Rep/Drosophila/data"
# export FLY_CEL_REP_EVALUATIONS="${REPO_ROOT}/2 - Cel Rep/Drosophila/evaluations"
# export FLY_CEL_REP_MODEL_WEIGHTS="${FLY_CEL_REP_DATA}/model_weights"
# export FLY_CEL_REP_INTERSPECIES_DATA="${REPO_ROOT}/2 - Cel Rep/Interspecies/data"

# --- Gene Rep (3 - Gene Rep) conda env + encoders ----------------------------
