# export GENE_REP_ENV="${CONDA_ENV_BASE}/gene_rep"
# export GENE_REP_ESM_MODEL="facebook/esm2_t36_3B_UR50D"        # 2560-d protein emb
# export GENE_REP_TEXT_MODEL="monologg/biobert_v1.1_pubmed"     # 768-d text emb
# Optional storage overrides if large artifacts live outside the repo.
